{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/arb",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/cron/correlation",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/cron/ai-prob",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/cron/market-making",
      "schedule": "0 0 * * *"
    }
  ],
]
}